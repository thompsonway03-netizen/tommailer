{
  "name": "tommailer",
  "version": "0.1.0",
  "main": "main.js",
  "scripts": {
    "dev": "npx concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server.js",
    "preview": "vite preview",
    "start": "electron .",
    "start:keygen": "electron keygen-main.js",
    "build:electron": "vite build && electron-builder --config electron-builder.yml --win nsis",
    "build:keygen": "electron-builder --config electron-builder-keygen.yml --win nsis",
    "build": "vite build",
    "generate-keys": "node generate-keys.js"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.4.5",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "express": "^4.18.2",
    "framer-motion": "^10.16.4",
    "lucide-react": "^0.263.1",
    "nodemailer": "^6.9.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.1"
  }
}